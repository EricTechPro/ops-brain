# Gmail Sync Configuration
# -----------------------

# Path to OAuth2 credentials (downloaded from GCP console)
GMAIL_CREDENTIALS_FILE=scripts/.gmail-credentials/credentials.json

# Path to store OAuth token (auto-generated on first auth)
GMAIL_TOKEN_FILE=scripts/.gmail-credentials/token.json

# Your email address (used to detect sent vs received)
GMAIL_USER_EMAIL=you@yourdomain.com

# Default temp directory for attachment downloads
GMAIL_DOWNLOAD_DIR=/tmp/gmail-sync
